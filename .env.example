# CVA Environment Configuration — copy to .env and edit

# Mode: demo | production
CVA_MODE=demo

# Video source: 0 = first webcam, 1 = second webcam, or a file path
CVA_VIDEO_SOURCE=0

# Storage backend: memory | sqlite
CVA_STORAGE=memory

# Candidate role for scoring weights: developer | sales | hr
CVA_ROLE=developer

# API server
CVA_API_HOST=0.0.0.0
CVA_API_PORT=8000

# ── Production only (not used in demo) ────────────────────────────
# KAFKA_BOOTSTRAP=localhost:9092
# REDIS_URL=redis://localhost:6379
# TRITON_URL=localhost:8001
